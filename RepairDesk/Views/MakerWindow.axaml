<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="RepairDesk.Views.MakerWindow"
        MinHeight="300"
        MinWidth="1000"
        Title="MakerWindow">
        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="*"/> 
                </Grid.RowDefinitions>
        
                <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/> 
                </Grid.ColumnDefinitions>
                
                
                <StackPanel Margin="10 10 0 0" Background="WhiteSmoke">
                        <TextBlock Text="Инженер:"/>
                        <TextBlock x:Name="engineerName" Text="Временная заглушка с именем"/>
                        
                        <StackPanel>
                                <DockPanel HorizontalAlignment="Left">
                                        <Menu DockPanel.Dock="Top">
                                                <!-- My applications-->
                                                <MenuItem Header="Мои заявки" Background="LightGray">
                                                        <MenuItem Header="Заявки"/>
                                                        <MenuItem Header="История ремонтов"/>
                                                        <MenuItem Header="Расчет зарплаты"/>
                                                        <MenuItem Header="Начало работы/конец"/>
                                                </MenuItem>
                                        </Menu>
                                </DockPanel>
                                
                                <DockPanel HorizontalAlignment="Left" Margin="0 10">
                                        <Menu DockPanel.Dock="Top">
                                                <!-- Fast access-->
                                                <MenuItem Header="Быстрый доступ" Background="LightGray">
                                                        <MenuItem Header="Техническая документация"/>
                                                        <MenuItem Header="Заметки по ремонту"/>
                                                        <MenuItem Header="Софт">
                                                                <MenuItem Header="Мобильные устройства"></MenuItem>
                                                                <MenuItem Header="Компьютерные устройства"></MenuItem>
                                                        </MenuItem>
                                                </MenuItem>
                                        </Menu>
                                </DockPanel>
                                
                                <DockPanel HorizontalAlignment="Left">
                                        <Menu DockPanel.Dock="Top">
                                                <!-- working with spare parts-->
                                                <MenuItem Header="Работа с запчастями" Background="LightGray">
                                                        <MenuItem Header="Проверка на складе запчастей"/>
                                                        <MenuItem Header="Создание заявок на заказ запчастей"/>
                                                </MenuItem>
                                        </Menu>
                                </DockPanel>
                                
                                <DockPanel HorizontalAlignment="Left" Margin="0 10">
                                        <Menu DockPanel.Dock="Top">
                                                <!-- Diagnostics and repair-->
                                                <MenuItem Header="Диагностика и ремонт" Background="LightGray">
                                                        <MenuItem Header="Чек лист по моделям/отчет"/>
                                                        <MenuItem Header="База типовых проблем, по моделям"/>
                                                        <!--MenuItem Header="Фотофиксация"/> хз вообще как сделать, думаю-->
                                                        <MenuItem Header="Сформировать отчет по работе"/> <!--возможно API Ollama AI-->
                                                        <MenuItem Header="Запчасти"/> <!--типо, чтобы здесь можно было выбрать заказ из тех которые ты уже начал делать и привязать к ниму какую нибудь деталь. К примеру - есть у нас на складе аккумулятор на Xiaomi poco ultra mega super max рекс ко мне. И мы должны будем привязать номер этой детали к этому телефону. -->
                                                </MenuItem>
                                        </Menu>
                                </DockPanel>
                        </StackPanel>
                </StackPanel>
        </Grid>
</Window>
