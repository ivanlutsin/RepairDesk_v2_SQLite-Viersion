<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:global="clr-namespace:"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RepairDesk.Views.AdminFunction.Additional_window.AddOrderWindow">
    
    <Grid>
        <StackPanel Spacing="8" Margin="10">

            <!-- Клиент -->
            <TextBox x:Name="ClientNameBox" Watermark="ФИО клиента"/>
            <MaskedTextBox x:Name="PhoneBox" Mask="+7 000 000 00 00" Watermark="Введите номер телефона клиента"/>

            <!-- Устройство -->
            <TextBox x:Name="DeviceBox" Watermark="Устройство"/>
            <TextBox x:Name="BrandBox" Watermark="Бренд"/>
            <TextBox x:Name="ModelBox" Watermark="Модель"/>
            <TextBox x:Name="SerialBox" Watermark="Серийный номер"/>

            <!-- Ремонт -->
            <TextBox x:Name="ProblemBox" Watermark="Проблема"/>
            <TextBox x:Name="EndDateBox" Watermark="Дата окончания (опц.)"/>

            <Button Content="Сохранить" Click="SaveClick"/>
            <Button Content="Очистить" Click="RefreshClick"/>

        </StackPanel>
    </Grid>

</UserControl>
