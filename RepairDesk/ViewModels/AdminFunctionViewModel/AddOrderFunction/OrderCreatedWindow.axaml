<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="RepairDesk.ViewModels.AdminFunctionViewModel.AddOrderFunction.OrderCreatedWindow"
        MaxWidth="400"
        MaxHeight="100"
        MinWidth="400"
        MinHeight="100"
        Title="Ответ">
    <Grid>
        <TextBlock x:Name="OrderText" FontSize="16" HorizontalAlignment="Center" Margin="10"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Печать" Click="PrintAddOrderClck" Width="150" HorizontalContentAlignment="Center"/>
            <Button Content="Ок" Click="CloseClick" Width="100" HorizontalContentAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
